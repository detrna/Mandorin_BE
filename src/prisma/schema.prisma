generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model appointments {
  id         Int      @id @default(autoincrement())
  location   String   @db.Text
  date       DateTime @db.Date
  time       String   @db.VarChar(64)
  note       String   @db.Text
  status     String   @db.VarChar(32)
  client_id  Int
  foreman_id Int
  clients    clients  @relation(fields: [client_id], references: [user_id], onDelete: Cascade, map: "fk_appointment-client")
  foreman    foreman  @relation(fields: [foreman_id], references: [user_id], onUpdate: Restrict, map: "fk_appointment-foreman")

  @@index([client_id], map: "fk_appointment-client")
  @@index([foreman_id], map: "fk_appointment-foreman")
}

model clients {
  user_id      Int            @id
  nick         String         @db.VarChar(16)
  role         String         @default("client") @db.VarChar(16)
  appointments appointments[]
  users        users          @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_client-user")
  projects     projects[]
  proposals    proposals[]
  reviews      reviews[]
}

model foreman {
  user_id      Int            @id
  nik          String         @db.VarChar(32)
  field        String         @db.VarChar(512)
  bio          String?        @db.Text
  strength     String?        @db.Text
  experience   Int
  portfolio    String?        @db.Text
  role         String         @default("foreman") @db.VarChar(16)
  appointments appointments[]
  users        users          @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_foreman-user")
  projects     projects[]
  proposals    proposals[]
  reviews      reviews[]
}

model images {
  id         Int      @id @default(autoincrement())
  url        String   @db.VarChar(64)
  report_id  Int
  review_id  Int
  project_id Int
  projects   projects @relation(fields: [project_id], references: [id], onDelete: Cascade, map: "fk_image-project")
  reports    reports  @relation(fields: [report_id], references: [id], onDelete: Cascade, map: "fk_image-report")

  @@index([project_id], map: "fk_image-project")
  @@index([report_id], map: "fk_image-report")
}

model jwt {
  id      String @id
  token   String @unique @db.VarChar(256)
  user_id Int
  users   users  @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_jwt-user")

  @@index([user_id], map: "fk_jwt-user")
}

model projects {
  id         Int          @id @default(autoincrement())
  field      String       @db.VarChar(128)
  title      String       @db.VarChar(128)
  content    String       @db.Text
  budget     Int
  deadline   DateTime     @db.Date
  location   String       @db.Text
  status     String       @db.VarChar(16)
  client_id  Int
  foreman_id Int
  created_at DateTime     @default(now()) @db.Date
  images     images[]
  milestones milestones[]
  clients    clients      @relation(fields: [client_id], references: [user_id], onDelete: Cascade, map: "fk_project-client")
  foreman    foreman      @relation(fields: [foreman_id], references: [user_id], onDelete: Cascade, map: "fk_project-foreman")
  reports    reports[]
  revisions  revisions[]

  @@index([client_id], map: "fk_project-client")
  @@index([foreman_id], map: "fk_project-foreman")
}

model proposals {
  id         Int      @id @default(autoincrement())
  budget     Int
  deadline   DateTime @db.Date
  field      String   @db.Text
  title      String   @db.VarChar(128)
  content    String   @db.Text
  location   String   @db.Text
  photo      String   @db.Text
  status     String   @db.VarChar(64)
  client_id  Int
  foreman_id Int
  created_at DateTime @default(now()) @db.Date
  clients    clients  @relation(fields: [client_id], references: [user_id], onDelete: Cascade, map: "fk_booking-client")
  foreman    foreman  @relation(fields: [foreman_id], references: [user_id], onUpdate: Restrict, map: "fk_booking-foreman")

  @@index([client_id], map: "fk_booking-client")
  @@index([foreman_id], map: "fk_booking-foreman")
}

model reports {
  id         Int      @id @default(autoincrement())
  title      String   @db.VarChar(128)
  content    String   @db.Text
  photo      String   @db.Text
  project_id Int
  created_at DateTime @default(now()) @db.Date
  images     images[]
  projects   projects @relation(fields: [project_id], references: [id], onDelete: Cascade, map: "fk_report-project")

  @@index([project_id], map: "fk_report-project")
}

model reviews {
  id         Int     @id @default(autoincrement())
  content    String  @db.VarChar(512)
  client_id  Int
  foreman_id Int
  score      Int
  clients    clients @relation(fields: [client_id], references: [user_id], onDelete: Cascade, map: "fk_review-client")
  foreman    foreman @relation(fields: [foreman_id], references: [user_id], onDelete: Cascade, map: "fk_review-foreman")

  @@index([client_id], map: "fk_review-client")
  @@index([foreman_id], map: "fk_review-foreman")
}

model revisions {
  id         Int      @id @default(autoincrement())
  content    String   @db.Text
  cause      String   @db.Text
  budget     Int
  deadline   DateTime @db.Date
  status     String   @default("MENUNGGU PERSETUJUAN") @db.VarChar(32)
  project_id Int
  created_at DateTime @default(now()) @db.Date
  projects   projects @relation(fields: [project_id], references: [id], onDelete: Cascade, map: "fk_revision-project")

  @@index([project_id], map: "fk_revision-project")
}

model users {
  id                             Int      @id @default(autoincrement())
  name                           String   @db.VarChar(256)
  birth_place                    String   @db.VarChar(64)
  birth_date                     DateTime @db.Date
  sex                            String   @db.VarChar(16)
  address                        String   @db.VarChar(256)
  email                          String   @unique @db.VarChar(256)
  password                       String   @db.VarChar(256)
  phone                          String   @db.VarChar(64)
  avatar                         String?  @db.Text
  chats_chats_receiver_idTousers chats[]  @relation("chats_receiver_idTousers")
  chats_chats_sender_idTousers   chats[]  @relation("chats_sender_idTousers")
  clients                        clients?
  foreman                        foreman?
  jwt                            jwt[]
}

model transactions {
  id          Int       @id @default(autoincrement())
  amount      Int?
  status      String?   @db.VarChar(128)
  created_at  DateTime  @default(now()) @db.DateTime(0)
  updated_at  DateTime? @db.DateTime(0)
  midtrans_id String?   @default(uuid())
  proposal_id Int       @unique
}

model milestones {
  id         Int      @id @default(autoincrement())
  title      String   @db.VarChar(128)
  content    String   @db.Text
  completed  Boolean  @default(false)
  deadline   DateTime @db.Date
  photo      String?  @db.Text
  project_id Int
  comment    String?  @db.Text
  projects   projects @relation(fields: [project_id], references: [id], onDelete: Cascade, map: "fk_milestone-project")

  @@index([project_id], map: "fk_milestone-project")
}

model chats {
  id                             Int       @id @default(autoincrement())
  content                        String    @db.Text
  image                          String    @db.Text
  sender_id                      Int
  receiver_id                    Int
  created_at                     DateTime  @default(now()) @db.DateTime(0)
  read_at                        DateTime? @db.DateTime(0)
  users_chats_receiver_idTousers users     @relation("chats_receiver_idTousers", fields: [receiver_id], references: [id], onDelete: Cascade, map: "fk_chat-user_receiver")
  users_chats_sender_idTousers   users     @relation("chats_sender_idTousers", fields: [sender_id], references: [id], onDelete: Cascade, map: "fk_chat-user_sender")

  @@index([receiver_id], map: "fk_chat-user_receiver")
  @@index([sender_id], map: "fk_chat-user_sender")
}
